# ============================================================
# Eternal Return 전적 검색 서비스 - 환경 변수 템플릿
# ============================================================
# 이 파일을 복사하여 .env 파일을 만드세요:
#   cp .env.example .env
# 그 다음 실제 값으로 교체하세요.
# ============================================================


# ── 이터널리턴 공식 API (백엔드 Python이 이 주소로만 요청합니다) ──
# 프론트 NEXT_PUBLIC_API_URL 은 로컬 FastAPI를 가리키는 것이 맞고, ER 직통이 아닙니다.
# 발급처: https://developer.bser.io
ER_API_KEY=your_eternal_return_api_key_here
ER_API_BASE_URL=https://open-api.bser.io


# ── Gemini AI ────────────────────────────────────────────────
# 발급처: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash


# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ergg_user:ergg_password@localhost:5432/ergg_db

# ── Supabase ────────────────────────────────────────────────
# supabase-py(백엔드)는 대시보드의 JWT 키(eyJ로 시작)가 필요합니다.
# sb_publishable_… 키만 있으면 Invalid API key가 날 수 있습니다.
#
# Project Settings → API 에서 복사:
# - SUPABASE_SERVICE_ROLE_KEY = service_role (서버 전용, RLS 우회·쓰기에 적합)
# - SUPABASE_ANON_KEY = anon public (RLS 적용, 쓰기는 정책 필요)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 프론트(Next 등)에서 쓰는 값 — URL 폴백용
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key_here


# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379


# ── JWT 인증 ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret_string_min_32_chars
JWT_EXPIRE_HOURS=24


# ── 앱 설정 ─────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
