# ER Open API Key (https://developer.bser.io)
ER_API_KEY=your_er_api_key_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://ergg_user:ergg_password@localhost:5432/ergg_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRE_HOURS=24

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
