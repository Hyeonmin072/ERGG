# ============================================================
# ERGG - .gitignore
# ============================================================

# ── 루트: 디렉터리만 추적, 루트 바로 아래 파일은 전부 무시 ───
# (backend/, frontend/, .claude/ 등 하위는 그대로 추적)
/*
!.gitignore
!*/
!.claude/


# ── 환경 변수 (절대 커밋 금지) ───────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production.local
frontend/.env.development.local


# ── Python / FastAPI ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.log


# ── Node.js / Next.js ────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
*.tsbuildinfo
.npm
.eslintcache


# ── IDE / 에디터 ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db


# ── Docker / DB 볼륨 ─────────────────────────────────────────
postgres-data/
redis-data/


# ── 기타 ─────────────────────────────────────────────────────
*.pem
*.key
*.cert
/claude

# ── 크롤링 산출물 ─────────────────────────────────────────────
backend/*.csv
*.txt
